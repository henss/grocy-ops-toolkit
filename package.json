{
  "name": "grocy-ops-toolkit",
  "version": "0.1.0",
  "description": "TypeScript toolkit for safe Grocy GitOps, health checks, and encrypted local backups",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henss/grocy-ops-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/henss/grocy-ops-toolkit/issues"
  },
  "homepage": "https://github.com/henss/grocy-ops-toolkit#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./backup-retention-simulation": {
      "types": "./dist/backup-retention-simulation.d.ts",
      "import": "./dist/backup-retention-simulation.js"
    },
    "./backup-retention-simulation-schema": {
      "types": "./dist/backup-retention-simulation-schema.d.ts",
      "import": "./dist/backup-retention-simulation-schema.js"
    }
  },
  "bin": {
    "grocy-ops-toolkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sample-consumer:smoke:workspace": "tsx scripts/generate-sample-consumer-smoke-workspace.ts",
    "grocy:demo:lab": "tsx src/cli.ts grocy:demo:lab",
    "grocy:quickstart:proof": "tsx src/cli.ts grocy:quickstart:proof",
    "grocy:evaluator:starter-pack": "tsx src/cli.ts grocy:evaluator:starter-pack",
    "grocy:init:workspace": "tsx src/cli.ts grocy:init:workspace",
    "grocy:install:doctor": "tsx src/cli.ts grocy:install:doctor",
    "grocy:config:status": "tsx src/cli.ts grocy:config:status",
    "grocy:health": "tsx src/cli.ts grocy:health",
    "grocy:health:badge": "tsx src/cli.ts grocy:health:badge",
    "grocy:health:diagnostics": "tsx src/cli.ts grocy:health:diagnostics",
    "grocy:inventory:snapshot": "tsx src/cli.ts grocy:inventory:snapshot",
    "grocy:shopping-state:export": "tsx src/cli.ts grocy:shopping-state:export",
    "grocy:desired-state:lint": "tsx src/cli.ts grocy:desired-state:lint",
    "grocy:compatibility:matrix": "tsx src/cli.ts grocy:compatibility:matrix",
    "grocy:compatibility:schema-capture": "tsx src/cli.ts grocy:compatibility:schema-capture",
    "grocy:bug-report:trace": "tsx src/cli.ts grocy:bug-report:trace",
    "grocy:compatibility:deprecation-canary": "tsx src/cli.ts grocy:compatibility:deprecation-canary",
    "grocy:coverage:playground": "tsx src/cli.ts grocy:coverage:playground",
    "grocy:namespace:prototype": "tsx src/cli.ts grocy:namespace:prototype",
    "grocy:smoke:mock": "tsx src/cli.ts grocy:smoke:mock",
    "grocy:smoke:secret-rotation": "tsx src/cli.ts grocy:smoke:secret-rotation",
    "grocy:fixtures:serve": "tsx src/cli.ts grocy:fixtures:serve",
    "grocy:export-config": "tsx src/cli.ts grocy:export-config",
    "grocy:diff-config": "tsx src/cli.ts grocy:diff-config",
    "grocy:config:drift-trend": "tsx src/cli.ts grocy:config:drift-trend",
    "grocy:config:migration-doctor": "tsx src/cli.ts grocy:config:migration-doctor",
    "grocy:apply-config": "tsx src/cli.ts grocy:apply-config",
    "grocy:backup:snapshot": "tsx src/cli.ts grocy:backup:snapshot",
    "grocy:backup:verify": "tsx src/cli.ts grocy:backup:verify",
    "grocy:backup:receipt": "tsx src/cli.ts grocy:backup:receipt",
    "grocy:backup:receipt:verify": "tsx src/cli.ts grocy:backup:receipt:verify",
    "grocy:backup:restore-plan": "tsx src/cli.ts grocy:backup:restore-plan",
    "grocy:backup:restore-drill": "tsx src/cli.ts grocy:backup:restore-drill",
    "grocy:backup:restore-failure-drill": "tsx src/cli.ts grocy:backup:restore-failure-drill",
    "grocy:backup:retention-simulate": "tsx src/cli.ts grocy:backup:retention-simulate",
    "grocy:review:dashboard": "tsx src/cli.ts grocy:review:dashboard",
    "grocy:artifacts:audit-redaction": "tsx src/cli.ts grocy:artifacts:audit-redaction",
    "grocy:support:bundle": "tsx src/cli.ts grocy:support:bundle",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "git-hooks:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-git-hooks.ps1",
    "check:agent-surface": "tsx scripts/check-agent-surface.ts",
    "check:agent-surface:preedit": "tsx scripts/check-agent-surface.ts",
    "check:agent-surface:staged": "tsx scripts/check-agent-surface.ts --staged",
    "refactor:extract-exports": "tsx scripts/refactor-extract-exports.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:typechecked": "eslint . --config eslint.typechecked.config.mjs",
    "verify:session": "npm run lint && npm run typecheck && npm run test && npm run check:agent-surface",
    "arch": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json --output-type err",
    "arch:baseline": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --output-type baseline --output-to .dependency-cruiser-known-violations.json",
    "arch:graph": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json --output-type mermaid"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^16.5.0",
    "ts-morph": "^27.0.2",
    "typescript-eslint": "^8.50.0",
    "dependency-cruiser": "^17.3.10"
  }
}
